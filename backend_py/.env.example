# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8000

# ─── Mock Mode ────────────────────────────────────────────────────────────────
# Set to true to skip Claude API — uses pre-written responses (great for demos)
MOCK_MODE=true

# ─── Claude API ───────────────────────────────────────────────────────────────
# Only required when MOCK_MODE=false
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
EMAIL_FROM=youragent@gmail.com
EMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
OWNER_EMAIL=owner@yourcompany.com

# ─── Client Contact Info (shown in applicant confirmation email) ──────────────
CONTACT_PHONE=+1 000-000-0000
CONTACT_EMAIL=info@yourcompany.com
CONTACT_WEBSITE=https://yourcompany.com

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
