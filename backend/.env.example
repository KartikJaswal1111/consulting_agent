# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── Mock Mode ────────────────────────────────────────────────────────────────
# Set to true to skip Claude API entirely — uses pre-written responses
# Perfect for demo testing without an API key. Set to false for production.
MOCK_MODE=true

# ─── Claude API ───────────────────────────────────────────────────────────────
# Only required when MOCK_MODE=false
# Get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# The Gmail account that SENDS the emails
EMAIL_FROM=youragent@gmail.com

# Gmail App Password (NOT your regular password)
# Generate at: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# The owner's inbox — applications get delivered here
OWNER_EMAIL=info@regalconsultinggroup.ca

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Add the WordPress site once live
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://regalconsultinggroup.ca
